                        keyPoints: `Faktor Keamanan lereng diperoleh sebesar FOS = ${res.toFixed(3)}.`,
                        adviceConclusion: `Kesimpulan: ${msg}`
                    };
                }
            },
            {
                id: "boussinesq-stress",
                title: "Boussinesq Stress Distribution",
                category: "stability-stress",
                symbol: "Δσz",
                expression: "Δσz = 3·q·z³ / [2·π · (r² + z²)^(5/2)]",
                desc: "Menghitung distribusi tambahan tegangan vertikal di dalam tanah akibat beban titik di permukaan.",
                inputs: [
                    { label: "Beban Titik Permukaan (q) [kN]", id: "q", placeholder: "Misal: 500" },
                    { label: "Kedalaman Ditinjau (z) [m]", id: "z", placeholder: "Misal: 4" },
                    { label: "Jarak Horizontal Radial (r) [m]", id: "r", placeholder: "0 jika tepat di bawah beban" }
                ],
                calc: (inputs) => {
                    const pembilang = 3 * inputs.q * Math.pow(inputs.z, 3);
                    const penyebut = 2 * Math.PI * Math.pow((Math.pow(inputs.r, 2) + Math.pow(inputs.z, 2)), 2.5);
                    return pembilang / penyebut;
                },
                unit: "kPa",
                softwareCor: "Prinsip dasar pembentukan kontur bulb tegangan subsoil.",
                interpret: (inputs, res) => {
                    return {
                        status: "aman",
                        inputMeaning: `Mentransfer beban titik permukaan sebesar ${inputs.q} kN pada kedalaman vertikal ${inputs.z} m.`,
                        keyPoints: `Tambahan tegangan vertikal bersih di titik target adalah ${res.toFixed(3)} kPa.`,
                        adviceConclusion: `Kesimpulan: Gunakan nilai delta stress ini untuk kalkulasi lanjutan penurunan konsolidasi.`
                    };
                }
            }
        ];

        let formulaCalculationHistory = {}; 
        let activeFormulaId = null;
        let currentCategory = "all";
        let currentTheme = "dark";

        document.addEventListener("DOMContentLoaded", () => {
            updateCategoryCounters();
            renderFormulaCards(formulaDatabase);
            initDraggablePanel(document.getElementById('draggableHelpPanel'), document.getElementById('helpDragHandle'));
            initLivePopUpTooltipEvents();
        });

        function initLivePopUpTooltipEvents() {
            const tooltipNode = document.getElementById("geoLiveTooltip");
            const container = document.getElementById("formulaContainer");
            
            container.addEventListener("mousemove", (e) => {
                const card = e.target.closest(".formula-card");
                if (!card) { tooltipNode.style.display = "none"; return; }
                
                const fId = card.getAttribute("data-formula-id");
                const item = formulaDatabase.find(f => f.id === fId);
                if (!item) return;

                let historyHTML = "";
                if (formulaCalculationHistory[fId]) {
                    let textBadgeColor = "color:#10b981; font-weight:bold;"; 
                    if (formulaCalculationHistory[fId].status === "kritis") textBadgeColor = "color:#f97316; font-weight:bold;"; 
                    if (formulaCalculationHistory[fId].status === "bahaya") textBadgeColor = "color:#ef4444; font-weight:bold;"; 

                    historyHTML = `
                        <div style="margin-top: 8px; padding-top: 6px; border-top: 2px dashed #f59e0b;">
                            <span style="${textBadgeColor}">[RIWAYAT TERAKHIR]:</span><br>
                            <span style="${textBadgeColor}">&bull; Hasil: ${formulaCalculationHistory[fId].result} ${item.unit || ''}</span><br>
                            <span style="color:var(--text-muted); font-size:11px;">&bull; Jam: ${formulaCalculationHistory[fId].time}</span>
                        </div>`;
                } else {
                    historyHTML = `
                        <div style="margin-top: 8px; padding-top: 6px; border-top: 1px dashed rgba(245,158,11,0.3); color:var(--text-muted); font-size:11px;">
                            <i class="fa-solid fa-calculator"></i> Belum ada kalkulasi riwayat aktif.
                        </div>`;
                }

                tooltipNode.style.display = "block";
                tooltipNode.style.left = (e.clientX + 18) + "px";
                tooltipNode.style.top = (e.clientY + 12) + "px";
                tooltipNode.innerHTML = `
                    <div style="color:#f59e0b; font-weight:900; border-b: 2px solid #f59e0b; padding-bottom:3px; margin-bottom:5px; font-size:13px;">
                        <i class="fa-solid fa-circle-info"></i> ${item.title}
                    </div>
                    <div style="font-size:12px; font-weight:600;">
                        ${item.desc}
                    </div>
                    ${historyHTML}`;
            });

            container.addEventListener("mouseleave", () => { tooltipNode.style.display = "none"; });
        }

        function toggleThemeInterface() {
            const body = document.getElementById('appBody');
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');

            if (currentTheme === "dark") {
                body.classList.remove('theme-dark'); body.classList.add('theme-light');
                icon.className = "fa-solid fa-sun"; text.innerText = "NORMAL MODE";
                currentTheme = "light";
            } else {
                body.classList.remove('theme-light'); body.classList.add('theme-dark');
                icon.className = "fa-solid fa-moon"; text.innerText = "DARK MODE";
                currentTheme = "dark";
            }
            filterDatabase();
        }

        function updateCategoryCounters() {
            document.getElementById("count-all").innerText = formulaDatabase.length;
            const cats = ["stress-strength", "flow-seepage", "settlement-consolidation", "earth-pressure", "stability-stress"];
            cats.forEach(cat => {
                const count = formulaDatabase.filter(f => f.category === cat).length;
                document.getElementById(`count-${cat}`).innerText = count;
            });
        }

        function renderFormulaCards(dataList) {
            const container = document.getElementById("formulaContainer");
            container.innerHTML = "";
            document.getElementById("itemCounter").innerText = `${dataList.length} Item Terdaftar`;

            if (dataList.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full text-center py-12 bg-slate-950/20 rounded-xl border-2 border-dashed border-slate-400 text-slate-500 font-mono text-xs font-bold">
                        <i class="fa-solid fa-folder-open text-3xl mb-2 block text-slate-400"></i>
                        Formula tidak ditemukan. Sesuaikan kata kunci pencarian Anda.
                    </div>`;
                return;
            }

            dataList.forEach(item => {
                let colorTheme = "";
                switch(item.category) {
                    case "stress-strength": colorTheme = "text-blue-600 border-blue-500 bg-blue-500/10"; break;
                    case "flow-seepage": colorTheme = "text-teal-600 border-teal-500 bg-teal-500/10"; break;
                    case "settlement-consolidation": colorTheme = "text-purple-600 border-purple-500 bg-purple-500/10"; break;
                    case "earth-pressure": colorTheme = "text-cyan-600 border-cyan-500 bg-cyan-500/10"; break;
                    case "stability-stress": colorTheme = "text-rose-600 border-rose-500 bg-rose-500/10"; break;
                }

                const card = document.createElement("div");
                card.className = "formula-card bg-[var(--bg-card)] p-5 rounded-xl border-2 border-[var(--border-color)] shadow-lg flex flex-col justify-between backdrop-blur-sm";
                card.setAttribute("data-formula-id", item.id);
                card.innerHTML = `
                    <div>
                        <div class="flex justify-between items-start gap-2 mb-3">
                            <span class="text-xs font-mono px-2 py-0.5 rounded border-2 ${colorTheme} tracking-wider font-black uppercase">${item.category.replace('-', ' ')}</span>
                            <span class="text-xl font-mono font-black text-slate-400/50 select-none">${item.symbol}</span>
                        </div>
                        <h3 class="text-sm font-black font-mono text-[var(--text-main)] mb-2 tracking-tight">${item.title}</h3>
                        <div class="bg-slate-950 px-3 py-2 rounded border border-slate-800 font-mono text-amber-500 font-black text-xs mb-3 shadow-inner overflow-x-auto whitespace-nowrap">
                            ${item.expression}
                        </div>
                        <p class="formula-desc text-[13px] text-[var(--text-muted)] mb-4 leading-relaxed">${item.desc}</p>
                        <div class="bg-[var(--bg-input)] border-l-4 border-amber-500 p-2 rounded-r font-mono text-[11px] text-[var(--text-muted)] mb-1 border-y border-r border-[var(--border-color)] font-bold">
                            <span class="font-black text-amber-500 block mb-0.5"><i class="fa-solid fa-circle-nodes mr-1 text-[9px]"></i>Konektivitas Pemodelan:</span>
                            ${item.softwareCor}
                        </div>
                    </div>
                    <div class="pt-3 border-t border-[var(--border-color)] flex justify-end">
                        <button onclick="openCalculator('${item.id}')" class="bg-[var(--bg-input)] hover:bg-amber-500 text-[var(--text-main)] hover:text-slate-950 font-mono font-black text-xs px-3 py-2 rounded transition-all flex items-center gap-1.5 shadow-sm cursor-pointer border-2 border-[var(--border-color)]">
                            <i class="fa-solid fa-calculator"></i> Buka Solver
                        </button>
                    </div>`;
                container.appendChild(card);
            });
        }

        function filterDatabase() {
            const query = document.getElementById("searchInput").value.toLowerCase();
            const filtered = formulaDatabase.filter(item => {
                const matchesSearch = item.title.toLowerCase().includes(query) || 
                                      item.desc.toLowerCase().includes(query) || 
                                      item.expression.toLowerCase().includes(query);
                const matchesCategory = currentCategory === "all" || item.category === currentCategory;
                return matchesSearch && matchesCategory;
            });
            renderFormulaCards(filtered);
        }

        function filterCategory(targetCat) {
            currentCategory = targetCat;
            const buttons = document.querySelectorAll(".cat-btn");
            buttons.forEach(btn => {
                btn.className = "cat-btn w-full text-left px-3 py-2.5 rounded-lg text-xs font-mono font-bold text-[var(--text-muted)] hover:bg-amber-500/10 flex items-center justify-between transition-colors cursor-pointer";
                const badge = btn.querySelector("span:last-child");
                if (badge) badge.className = "text-xs bg-slate-400/20 text-[var(--text-main)] px-2 py-0.5 rounded-full font-black";
            });

            if (event && event.currentTarget) {
                const currentBtn = event.currentTarget;
                currentBtn.className = "cat-btn w-full text-left px-3 py-2.5 rounded-lg text-xs font-mono font-bold bg-amber-500 text-slate-950 flex items-center justify-between transition-colors cursor-pointer";
                const currentBadge = currentBtn.querySelector("span:last-child");
                if (currentBadge) currentBadge.className = "text-xs bg-slate-900/20 px-2 py-0.5 rounded-full font-black";
            }

            const titleMap = {
                'all': 'Menampilkan Semua Formula',
                'stress-strength': 'Geoteknik - Stress & Strength Mechanical Analysis',
                'flow-seepage': 'Geoteknik - Flow & Groundwater Seepage Analysis',
                'settlement-consolidation': 'Geoteknik - Settlement & Cohesive Soil Consolidation',
                'earth-pressure': 'Geoteknik - Lateral Earth Pressure Retaining Wall',
                'stability-stress': 'Geoteknik - Slope Stability & Stress Distribution'
            };
            document.getElementById("currentCategoryTitle").innerText = titleMap[targetCat] || titleMap['all'];
            filterDatabase();
        }

        function openCalculator(id) {
            const item = formulaDatabase.find(f => f.id === id);
            if (!item) return;

            activeFormulaId = id;
            document.getElementById("modalTitle").innerText = item.title;
            document.getElementById("modalMathExpression").innerText = item.expression;
            
            const inputsContainer = document.getElementById("dynamicInputs");
            inputsContainer.innerHTML = "";
            document.getElementById("resultBox").classList.add("hidden");

            item.inputs.forEach(inp => {
                const block = document.createElement("div");
                block.className = "flex flex-col";
                block.innerHTML = `
                    <label class="font-black text-slate-300 mb-1">${inp.label}</label>
                    <input type="number" id="input-${inp.id}" step="any" placeholder="${inp.placeholder}" 
                        class="w-full px-3 py-2 bg-slate-950 border-2 border-slate-800 rounded text-slate-100 focus:outline-none focus:border-amber-500 font-mono text-xs font-bold">`;
                inputsContainer.appendChild(block);
            });

            document.getElementById("calcModal").classList.remove("hidden");
        }

        function closeCalculator() {
            document.getElementById("calcModal").classList.add("hidden");
            activeFormulaId = null;
        }

        function askGeoBotAboutCurrentFormula() {
            if (!activeFormulaId) return;
            const item = formulaDatabase.find(f => f.id === activeFormulaId);
            if (!item) return;

            const chatWin = document.getElementById("chatWindow");
            const icon = document.getElementById("chatTriggerIcon");
            chatWin.classList.remove("hidden");
            icon.className = "fa-solid fa-xmark text-lg";

            const promptMessage = `Beri tahu saya batas kritis dan bahaya operasional untuk rumus: ${item.title} (${item.symbol})`;
            sendQuickQuestion(promptMessage);
        }

        function calculateResult() {
            const current = formulaDatabase.find(f => f.id === activeFormulaId);
            if (!current) return;

            const values = {}; let isComplete = true;

            current.inputs.forEach(inp => {
                const val = document.getElementById(`input-${inp.id}`).value;
                if (val === "") isComplete = false;
                values[inp.id] = parseFloat(val);
            });

            if (!isComplete) { alert("Harap lengkapi seluruh parameter laboratorium!"); return; }

            try {
                const output = current.calc(values);
                const outBox = document.getElementById("resultBox");
                const calcOut = document.getElementById("calcOutput");
                const resBorderBox = document.getElementById("resultBorderBox");
                const resTitleLabel = document.getElementById("resultTitleLabel");
                const rounded = Number(output.toFixed(4));
                
                let evaluationNode = "";
                let logs = current.interpret ? current.interpret(values, rounded) : { status: "aman", inputMeaning: "", keyPoints: "", adviceConclusion: "" };

                resBorderBox.className = "bg-slate-950 p-4 rounded-lg border-2 shadow-inner transition-colors";
                
                if (logs.status === "kritis") {
                    evaluationNode = " <span class='text-orange-500 text-xs font-black border border-orange-500/30 px-1.5 py-0.5 rounded bg-orange-950/40 uppercase tracking-wider'>(Kritis)</span>";
                    calcOut.className = "text-xl font-mono font-black text-orange-500 drop-shadow-[0_0_6px_rgba(249,115,22,0.4)]";
                    resBorderBox.classList.add("border-orange-500");
                    resTitleLabel.className = "text-[10px] text-orange-500 font-mono font-bold uppercase tracking-wider block mb-1";
                } else if (logs.status === "bahaya") {
                    evaluationNode = " <span class='text-red-500 text-xs font-black border border-red-500/30 px-1.5 py-0.5 rounded bg-red-950/40 uppercase tracking-wider'>(Bahaya / Tidak Aman)</span>";
                    calcOut.className = "text-xl font-mono font-black text-red-500 drop-shadow-[0_0_6px_rgba(239,68,68,0.4)]";
                    resBorderBox.classList.add("border-red-500");
                    resTitleLabel.className = "text-[10px] text-red-500 font-mono font-bold uppercase tracking-wider block mb-1";
                } else {
                    evaluationNode = " <span class='text-emerald-400 text-xs font-bold border border-emerald-500/30 px-1.5 py-0.5 rounded bg-emerald-950/40'>(Aman)</span>";
                    calcOut.className = "text-xl font-mono font-black text-emerald-400";
                    resBorderBox.classList.add("border-emerald-500");
                    resTitleLabel.className = "text-[10px] text-emerald-400 font-mono font-bold uppercase tracking-wider block mb-1";
                }

                calcOut.innerHTML = `${rounded} ${current.unit || ''} ${evaluationNode}`;

                if (current.interpret) {
                    document.getElementById("logInputMeaning").innerHTML = `<strong><i class="fa-solid fa-right-to-bracket text-amber-500/70 mr-1"></i> Input Deskriptif:</strong> ${logs.inputMeaning}`;
                    document.getElementById("logKeyPoints").innerHTML = `<strong><i class="fa-solid fa-chart-line text-cyan-400/70 mr-1"></i> Poin Kunci Analisis:</strong> ${logs.keyPoints}`;
                    
                    const adviceBox = document.getElementById("logAdviceConclusion");
                    adviceBox.innerHTML = `<strong><i class="fa-solid fa-clipboard-check mr-1"></i> Saran & Kesimpulan Rekayasa:</strong><br>${logs.adviceConclusion}`;
                    
                    if (logs.status === "kritis") { adviceBox.className = "text-orange-400 bg-orange-950/40 p-2 rounded border border-orange-500 mt-1 font-bold"; }
                    else if (logs.status === "bahaya") { adviceBox.className = "text-red-400 bg-red-950/40 p-2 rounded border border-red-500 mt-1 font-black"; }
                    else { adviceBox.className = "text-emerald-400 bg-emerald-950/40 p-2 rounded border border-emerald-500 mt-1 font-bold"; }
                }

                formulaCalculationHistory[activeFormulaId] = {
                    result: rounded, status: logs.status, time: new Date().toLocaleTimeString('id-ID')
                };
                outBox.classList.remove("hidden");
            } catch (err) { alert("Terjadi kesalahan aritmatika komputasi numerik."); }
        }

        function openHelpModal() {
            const modal = document.getElementById('helpModal');
            modal.classList.remove('hidden');
        }
        function closeHelpModal() { document.getElementById('helpModal').classList.add('hidden'); }

        function initDraggablePanel(panel, handle) {
            let p1 = 0, p2 = 0, p3 = 0, p4 = 0;
            handle.onmousedown = startDrag; handle.ontouchstart = startTouchDrag;
            
            function startDrag(e) {
                e.preventDefault();
                p3 = e.clientX; p4 = e.clientY; document.onmouseup = endDrag; document.onmousemove = moveDrag;
            }
            function moveDrag(e) {
                e.preventDefault(); p1 = p3 - e.clientX; p2 = p4 - e.clientY; p3 = e.clientX; p4 = e.clientY;
                panel.style.top = (panel.offsetTop - p2) + "px"; panel.style.left = (panel.offsetLeft - p1) + "px";
            }
            function endDrag() { document.onmouseup = null; document.onmousemove = null; }

            function startTouchDrag(e) {
                p3 = e.touches[0].clientX; p4 = e.touches[0].clientY;
                document.ontouchend = endTouchDrag; document.ontouchmove = moveTouchDrag;
            }
            function moveTouchDrag(e) {
                p1 = p3 - e.touches[0].clientX; p2 = p4 - e.touches[0].clientY; p3 = e.touches[0].clientX; p4 = e.touches[0].clientY;
                panel.style.top = (panel.offsetTop - p2) + "px"; panel.style.left = (panel.offsetLeft - p1) + "px";
            }
            function endTouchDrag() { document.ontouchend = null; document.ontouchmove = null; }
        }

        function toggleFloatingChat() {
            const chatWin = document.getElementById("chatWindow"); const icon = document.getElementById("chatTriggerIcon");
            if(chatWin.classList.contains("hidden")) { chatWin.classList.remove("hidden"); icon.className = "fa-solid fa-xmark text-lg"; }
            else { chatWin.classList.add("hidden"); icon.className = "fa-solid fa-comments text-lg"; }
        }

        function appendChatMessage(sender, text) {
            const container = document.getElementById("chatMessages"); const msgEl = document.createElement("div");
            if(sender === "user") { msgEl.className = "bg-amber-500 text-slate-950 p-2.5 rounded-lg max-w-[85%] self-end ml-auto font-bold shadow-sm border border-amber-400"; }
            else { msgEl.className = "bg-slate-800 text-slate-100 p-2.5 rounded-lg max-w-[85%] self-start border border-slate-700 leading-relaxed shadow-sm font-medium"; }
            msgEl.innerHTML = text; container.appendChild(msgEl); container.scrollTop = container.scrollHeight;
        }

        function sendQuickQuestion(questionText) { appendChatMessage("user", questionText); processBotResponse(questionText); }

        function handleChatSubmit(e) {
            e.preventDefault(); const input = document.getElementById("chatInput"); const query = input.value.trim();
            if(!query) return; appendChatMessage("user", query); input.value = ""; processBotResponse(query);
        }

        function processBotResponse(query) {
            const cleaned = query.toLowerCase();
            let reply = "Maaf, saya tidak memahami perintah tersebut. Silakan tanyakan tentang batas kriteria stabilitas lereng (FOS), sand boiling, atau penurunan konsolidasi.";
            
            if (cleaned.includes("fos") || cleaned.includes("lereng") || cleaned.includes("keamanan") || cleaned.includes("stability")) {
                reply = `Untuk stabilitas lereng, batas keamanannya adalah:<br>
                • <strong style="color:#f97316;">Kritis</strong>: 1.0 ≤ FOS &lt; 1.5 (rentan akibat beban air atau gempa dinamis).<br>
                • <strong style="color:#ef4444;">Bahaya/Gagal</strong>: FOS &lt; 1.0 (potensi runtuh atau longsor langsung).`;
            } else if (cleaned.includes("boiling") || cleaned.includes("piping") || cleaned.includes("hidrolik") || cleaned.includes("gradient")) {
                reply = `Gradien hidrolik (i = h / L) memiliki batas kriteria:<br>
                • <strong style="color:#f97316;">Kritis</strong>: i ≥ 0.75 (kecepatan aliran tinggi mendekati kritis).<br>
                • <strong style="color:#ef4444;">Bahaya/Tidak Aman</strong>: i ≥ 1.0 (terjadi efek kegagalan sand boiling / piping struktural).`;
            } else if (cleaned.includes("penurunan") || cleaned.includes("lempung") || cleaned.includes("settlement")) {
                reply = `Batas penurunan konsolidasi primer (Sc) pada lempung:<br>
                • <strong style="color:#f97316;">Kritis</strong>: Penurunan &gt; 50 mm. Memicu risiko tinggi keretakan struktural bangunan.`;
            } else if (cleaned.includes("cc") || cleaned.includes("kompresi")) {
                reply = `Pada Indeks Kompresi Empiris (Cc):<br>
                • <strong style="color:#f97316;">Kritis</strong>: Cc &gt; 0.3 menandakan kompresibilitas tanah sangat tinggi (sangat mudah mampat).`;
            } else if (cleaned.includes("stress") || cleaned.includes("pori") || cleaned.includes("efektif") || cleaned.includes("bearing")) {
                reply = `Pada prinsip tegangan efektif (sigma' = sigma - u):<br>
                • <strong style="color:#f97316;">Kritis</strong>: Rasio tekanan air pori terhadap beban total (u / sigma) ≥ 0.5.<br>
                • <strong style="color:#ef4444;">Bahaya/Tidak Aman</strong>: Ketika u = sigma, kuat geser tanah hilang total (likuifaksi).`;
            }

            setTimeout(() => { appendChatMessage("bot", reply); }, 400);
        }
    </script>
</body>
